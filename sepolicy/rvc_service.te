# Domain for the RearView Camera gear monitor (/vendor/bin/rvc_service)

type rvc_service,      domain;
type rvc_service_exec, exec_type, vendor_file_type, file_type;

# Allow init to spawn rvc_service and transition into its domain
init_daemon_domain(rvc_service)

# HIDL Vehicle HAL client (handles hwbinder + hwservice_manager internally)
hal_client_domain(rvc_service, hal_vehicle)

# Write vendor.rvc.camera.active to signal rvc_app
set_prop(rvc_service, vendor_rvc_prop)
